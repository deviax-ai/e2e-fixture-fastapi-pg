# Postgres connection string.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/notes

# App-level secret used for signing things. Override in prod with a
# 32+ random string. The hardcoded fallback in app/main.py is dev-only.
SECRET_KEY=fixtures-secret-do-not-ship

# Listening port. Most platforms inject PORT — uvicorn reads it via
# the --port arg in the Dockerfile CMD.
PORT=8000
